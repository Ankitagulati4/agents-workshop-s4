# Copy to .env and fill in your values
# cp .env.example .env

# ── Required (pick ONE: Groq free tier, or OpenAI) ───────────────────────────
# Groq (free, recommended): https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# OpenAI (paid): https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ── Model name ───────────────────────────────────────────────────────────────
# For Groq:   llama-3.3-70b-versatile   |   llama-3.1-8b-instant
# For OpenAI: gpt-4o-mini
OPENAI_MODEL_NAME=llama-3.3-70b-versatile

# ── Optional: search tools ───────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Optional: GitHub MCP homework ────────────────────────────────────────────
# Create a fine-grained token at github.com/settings/tokens
# Scopes needed: repo (read), issues (read/write)
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=your-username/your-repo

# ── Optional: LangSmith tracing ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=s4-tools-communication

# ── A2A lab ports ────────────────────────────────────────────────────────────
AGENT_A_PORT=8001
AGENT_B_PORT=8002
